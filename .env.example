CI_ENVIRONMENT = development

app.baseURL = 'http://localhost:8080/'

# -------------------------------------------------------------------
# Local default: SQLite for easy setup
# -------------------------------------------------------------------
# Leave these commented to use the app's default SQLite config.
# If you want to be explicit, you can uncomment them:
# database.default.DBDriver = SQLite3
# database.default.database = writable/database/dev.sqlite
# database.default.DBPrefix =
# database.default.foreignKeys = true

# -------------------------------------------------------------------
# Deployment target: MySQL
# Uncomment and adjust these for a MySQL environment.
# -------------------------------------------------------------------
# database.default.hostname = localhost
# database.default.database = municipal_asset_tracker
# database.default.username = root
# database.default.password =
# database.default.DBDriver = MySQLi
# database.default.DBPrefix =
# database.default.port = 3306

# PHPUnit / local automated tests
database.tests.DBDriver = SQLite3
database.tests.database = :memory:
database.tests.DBPrefix = db_
database.tests.foreignKeys = true
